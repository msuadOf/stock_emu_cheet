{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StocksSaveEditor",
  "version": "0.2.0",
  "identifier": "com.stockssaveeditor.app",
  "build": {
    "frontendDist": "../src/gui/dist-frontend",
    "features": ["pytauri/standalone"]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "StocksMainForceSimulator 存档编辑器",
        "width": 1000,
        "height": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
